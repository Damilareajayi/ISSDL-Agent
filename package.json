{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n \"api,web\" -c \"cyan,magenta\" --kill-others-on-fail \"pnpm --filter @workspace/api-server dev\" \"pnpm --filter @workspace/sdl-intelligence dev\"",
    "build": "pnpm --filter @workspace/sdl-intelligence build && pnpm --filter @workspace/api-server build",
    "start": "pnpm --filter @workspace/api-server start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "esbuild", "msw", "unrs-resolver"]
  }
}
