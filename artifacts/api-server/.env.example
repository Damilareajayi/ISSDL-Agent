PORT=8080
NODE_ENV=development
GEMINI_API_KEY=your_gemini_api_key_here
# Gemini model name — change if gemini-2.0-flash is unavailable on your key
# Common alternatives: gemini-1.5-flash  gemini-1.5-pro  gemini-2.5-flash
GEMINI_MODEL=gemini-1.5-flash
# Optional — get a free key at https://core.ac.uk/services/api
CORE_API_KEY=
